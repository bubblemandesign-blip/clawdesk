{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ClawDesk",
    "version": "0.1.0",
    "identifier": "app.clawdesk",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "ClawDesk",
                "width": 900,
                "height": 700,
                "center": true,
                "decorations": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:18789 ws://localhost:18789 https://api.anthropic.com https://api.openai.com; frame-src http://localhost:18789;"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "notification": {
            "all": true
        }
    }
}