{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawDesk",
  "version": "0.1.1",
  "identifier": "com.clawdesk.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClawDesk",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' http://localhost:18789 ws://localhost:18789 https://api.anthropic.com https://api.openai.com https://api.groq.com https://api.moonshot.cn https://api.deepseek.com https://generativelanguage.googleapis.com; frame-src http://localhost:18789;"
    },
    "externalBin": [
      "binaries/openclaw"
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "en-US",
        "bannerPath": "assets/installer-banner.bmp",
        "dialogImagePath": "assets/installer-dialog.bmp"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "assets/installer-banner.bmp",
        "sidebarImage": "assets/installer-dialog.bmp"
      },
      "msix": {}
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    }
  }
}